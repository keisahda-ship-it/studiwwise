<script>
function switchTab(id, btn, groupId) {
  const grp = document.getElementById(groupId);
  grp.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const sec = grp.closest('section') || document.body;
  sec.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const el = document.getElementById('tab-' + id);
  if (el) el.classList.add('active');
}
function toggleMenu() { document.getElementById('mobMenu').classList.toggle('open'); }
function closeMenu() { document.getElementById('mobMenu').classList.remove('open'); }
document.addEventListener('click', e => {
  const m = document.getElementById('mobMenu');
  if (!document.querySelector('nav').contains(e.target) && m.classList.contains('open')) m.classList.remove('open');
});
const obs = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) { setTimeout(() => e.target.classList.add('vis'), i * 50); obs.unobserve(e.target); }
  });
}, { threshold: 0.07 });
document.querySelectorAll('.rv').forEach(el => obs.observe(el));
</script>
